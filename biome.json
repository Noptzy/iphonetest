{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignore": [
			"**/dist/**",
			"**/node_modules/**",
			"**/drizzle/**",
			"**/routeTree.gen.ts",
			"**/uploads/**"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "asNeeded"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": {
				"useArrayIndexKey": "off"
			}
		}
	},
	"overrides": [
		{
			"include": ["**/main.ts", "**/better-auth.ts", "**/seed.ts", "**/polyfill.ts"],
			"linter": {
				"rules": {
					"style": { "noNonNullAssertion": "off" },
					"suspicious": { "noExplicitAny": "off" }
				}
			}
		},
		{
			"include": ["**/components/ui/**"],
			"linter": {
				"rules": {
					"style": { "noDocumentCookie": "off" },
					"security": { "noDangerouslySetInnerHtml": "off" }
				}
			}
		}
	]
}
