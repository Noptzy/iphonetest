{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": [
			"**",
			"!**/dist/**",
			"!**/node_modules/**",
			"!**/drizzle/**",
			"!**/routeTree.gen.ts",
			"!**/uploads/**"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "asNeeded"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"correctness": {
				"noChildrenProp": "off"
			},
			"a11y": {
				"noLabelWithoutControl": "off"
			}
		}
	},
	"overrides": [
		{
			"includes": ["**/main.ts", "**/better-auth.ts", "**/seed.ts", "**/polyfill.ts"],
			"linter": {
				"rules": {
					"style": { "noNonNullAssertion": "off" },
					"suspicious": { "noExplicitAny": "off" }
				}
			}
		},
		{
			"includes": ["**/components/ui/**"],
			"linter": {
				"rules": {
					"style": {},
					"security": { "noDangerouslySetInnerHtml": "off" }
				}
			}
		}
	]
}
